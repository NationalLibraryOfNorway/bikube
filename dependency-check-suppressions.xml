    <packageUrl regex="true">^pkg:maven/org\.apache\.tomcat\.embed/.*$</packageUrl>
    <cve>CVE-2026-53434</cve>
  </suppress>
  <suppress>
    <packageUrl regex="true">^pkg:maven/org\.apache\.tomcat\.embed/.*$</packageUrl>
    <cve>CVE-2026-55276</cve>
