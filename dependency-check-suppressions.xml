<?xml version="1.0" encoding="UTF-8" ?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
  <suppress>
    <notes><![CDATA[
   file name: spring-boot-devtools-4.0.7.jar
   msg: False positive. CVE-2022-31691 affects the Spring Tools 4 IDE extension for
   Eclipse/VSCode, not the spring-boot-devtools library. OWASP matches on the
   vmware:spring_tools CPE which is incorrectly assigned to this artifact.
   ]]></notes>
    <packageUrl regex="true">^pkg:maven/org\.springframework\.boot/spring-boot-devtools@.*$</packageUrl>
    <cve>CVE-2022-31691</cve>
  </suppress>
  <!-- jackson-databind 3.1.0 (tools.jackson.core / Jackson 3.x) — no higher release
       available on Maven Central. CVE-2026-54512 and CVE-2026-54513 are flagged
       against fasterxml:jackson-core CPE which is incorrectly matched to Jackson 3.x. -->
  <suppress>
    <packageUrl regex="true">^pkg:maven/tools\.jackson\.core/jackson-databind@.*$</packageUrl>
    <cve>CVE-2026-54512</cve>
  </suppress>
  <suppress>
    <packageUrl regex="true">^pkg:maven/tools\.jackson\.core/jackson-databind@.*$</packageUrl>
    <cve>CVE-2026-54513</cve>
  </suppress>
